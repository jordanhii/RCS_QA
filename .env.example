# 复制本文件为 .env 并填入真实值（.env 已在 .gitignore 中，不会被提交）

# ── 服务器 / 数据库 ─────────────────────────────────────────────
# 端口：部署平台通常自动注入 PORT，本地可留空（默认 3000）
PORT=3000
# 数据库连接串：本地默认 mongodb://127.0.0.1:27017/qa_alert_system
# 线上用 MongoDB Atlas，例如 mongodb+srv://user:pass@cluster.xxx.mongodb.net/qa_alert_system
MONGODB_URI=mongodb://127.0.0.1:27017/qa_alert_system
# 额外放行的前端域名（前后端同域部署时可不填），多个用逗号分隔
CORS_ORIGINS=

# ── 安全密钥（上线务必设置为随机长串；本地已自动生成 APP_SECRET_KEY）──
APP_SECRET_KEY=          # 账号密码/OTP 的加密主密钥；换了它数据库里已存的账号将无法解密
JWT_SECRET=              # 登录令牌签名密钥（不设则用不安全的默认值）
WORKER_TOKEN=           # 同步/导出脚本访问后端的令牌；脚本端要与此一致

# ── 初始管理员（首次启动无 admin 时自动创建，登录后请改密码）─────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123

# ── RC 账号 ──────────────────────────────────────────────────────
# 说明：这些只在「首次启动」时被加密导入到数据库的账号配置；之后统一在
#      系统「接口配置」页面管理，改这里不再影响已导入的账号。
# 测试站 (platform88.me)
RC_USERNAME=your_username
RC_PASSWORD=your_password
RC_OTP_SECRET=your_totp_secret
# 正式站 (platform10.me)
RC_PROD_USERNAME=
RC_PROD_PASSWORD=
RC_PROD_OTP_SECRET=

BACKEND_URL=http://localhost:3000
